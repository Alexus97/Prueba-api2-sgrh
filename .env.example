# Build
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Database
DB_DRIVER=mysql
DB_HOST=mysql
DB_PORT=3306
DB_NAME=hotel_tolimagrande
DB_USERNAME=root
DB_PASSWORD=root

# Spring profiles
SPRING_PROFILES_ACTIVE=prod

# JWT
JWT_SECRET=your-secret-key-here-min-256-chars-your-secret-key-here-min-256-chars
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/sgrsh

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_SGRH_SGRH=DEBUG

# Timezone
TZ=America/Bogota
